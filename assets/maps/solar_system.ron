(
  // ── Solar System Simulation ────────────────────────────────────────────────
  //
  // A star + 4 planets at increasing distances.
  // Life emerges only in the habitable zone — not programmed, axiom-derived.
  //
  // Layout (128×128 grid, 1 cell = 1 AU/16):
  //
  //   ┌─────────────────────────────────────────────────────┐
  //   │                                                     │
  //   │                    ○ Glacius (frozen)                │
  //   │                                                     │
  //   │              ○ Oceanus (habitable?)                  │
  //   │                                                     │
  //   │         ○ Terra (habitable zone)                     │
  //   │                                                     │
  //   │     ○ Ignis (too hot)                               │
  //   │                                                     │
  //   │  ★ SOL                                              │
  //   │                                                     │
  //   └─────────────────────────────────────────────────────┘
  //
  // SOL: massive emission, never depletes. Axiom 5: external input.
  // Each planet: geothermal core + surface conditions from distance to sol.
  // Habitable zone: where solar_qe_at_distance ∈ [abiogenesis_min, plasma_threshold].
  //
  // Expected:
  //   Ignis:   too much energy → Plasma state → no stable structures
  //   Terra:   goldilocks → life emerges → colonies → culture → division
  //   Oceanus: borderline → sparse life near geothermal vents
  //   Glacius: too cold → only geothermal extremophiles (if any)

  width_cells: 128,
  height_cells: 128,
  cell_size: 2.0,
  origin: (-128.0, -128.0),
  warmup_ticks: Some(120),
  seed: Some(42),
  fog_of_war: false,
  playfield_margin_cells: None,

  // Faint primordial background (cosmic microwave equivalent).
  initial_field_qe: Some(2.0),
  initial_field_freq: Some(50.0),
  initial_nutrient_water: Some(0.1),

  nuclei: [

    // ══════════════════════════════════════════════════════════════════════
    //  ★ SOL — the star
    // ══════════════════════════════════════════════════════════════════════
    // Center-left of grid. Massive emission. Huge radius covers all planets.
    // Frequency 400 Hz (photosynthetic resonance band).
    // Reservoir effectively infinite for simulation timescale.
    (
      name: "sol",
      position: (-80.0, 0.0),
      frequency_hz: 400.0,
      emission_rate_qe_s: 2000.0,
      propagation_radius: 120.0,
      decay: InverseSquare,
      ambient_pressure: None,
      reservoir: Some(999999.0),
    ),

    // ══════════════════════════════════════════════════════════════════════
    //  PLANET 1: IGNIS — too close, scorched
    // ══════════════════════════════════════════════════════════════════════
    // Distance: 20 units from Sol. Receives intense radiation.
    // Small geothermal core. Surface dominated by solar input → Plasma/Gas.
    (
      name: "ignis_core",
      position: (-60.0, 0.0),
      frequency_hz: 440.0,
      emission_rate_qe_s: 100.0,
      propagation_radius: 8.0,
      decay: InverseSquare,
      ambient_pressure: None,
    ),

    // ══════════════════════════════════════════════════════════════════════
    //  PLANET 2: TERRA — habitable zone
    // ══════════════════════════════════════════════════════════════════════
    // Distance: 45 units from Sol. Goldilocks energy level.
    // Geothermal core + ocean + continent. Life should emerge here.
    (
      name: "terra_core",
      position: (-35.0, 0.0),
      frequency_hz: 55.0,
      emission_rate_qe_s: 150.0,
      propagation_radius: 12.0,
      decay: InverseSquare,
      ambient_pressure: None,
    ),
    (
      name: "terra_ocean",
      position: (-38.0, 5.0),
      frequency_hz: 200.0,
      emission_rate_qe_s: 80.0,
      propagation_radius: 10.0,
      decay: InverseLinear,
      ambient_pressure: None,
    ),
    (
      name: "terra_continent",
      position: (-32.0, -3.0),
      frequency_hz: 85.0,
      emission_rate_qe_s: 60.0,
      propagation_radius: 8.0,
      decay: InverseLinear,
      ambient_pressure: None,
    ),

    // ══════════════════════════════════════════════════════════════════════
    //  PLANET 3: OCEANUS — outer habitable edge
    // ══════════════════════════════════════════════════════════════════════
    // Distance: 70 units from Sol. Low solar flux. Mostly ocean.
    // Life possible near hydrothermal vents (geothermal core).
    (
      name: "oceanus_core",
      position: (-10.0, 0.0),
      frequency_hz: 50.0,
      emission_rate_qe_s: 120.0,
      propagation_radius: 10.0,
      decay: InverseSquare,
      ambient_pressure: None,
    ),
    (
      name: "oceanus_ocean",
      position: (-12.0, 4.0),
      frequency_hz: 210.0,
      emission_rate_qe_s: 100.0,
      propagation_radius: 12.0,
      decay: InverseLinear,
      ambient_pressure: None,
    ),

    // ══════════════════════════════════════════════════════════════════════
    //  PLANET 4: GLACIUS — frozen outer world
    // ══════════════════════════════════════════════════════════════════════
    // Distance: 100 units from Sol. Almost no solar energy.
    // Tiny geothermal core. Surface is dark and cold.
    // Only extremophile life possible (if geothermal coherence > dissipation).
    (
      name: "glacius_core",
      position: (20.0, 0.0),
      frequency_hz: 50.0,
      emission_rate_qe_s: 60.0,
      propagation_radius: 6.0,
      decay: InverseSquare,
      ambient_pressure: None,
    ),
  ],
  seasons: [],
)
