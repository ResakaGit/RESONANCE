(
  // ── Earth (Real Geography) ─────────────────────────────────────────────────
  //
  // Continentes mapeados a posiciones reales en proyección equirectangular.
  // Continents mapped to real positions in equirectangular projection.
  //
  // Grid 64×32: X = longitud (-180° → +180°), Y = latitud (-90° → +90°).
  // Cada celda ≈ 5.6° × 5.6° ≈ 625 km.
  //
  // Nuclei Terra (85 Hz) = tierra firme.
  // Nuclei Aqua (200 Hz) = océanos profundos.
  // Sol infinito arriba. Geotermia en el centro.
  //
  width_cells: 64,
  height_cells: 32,
  cell_size: 2.0,
  origin: (-64.0, -32.0),
  warmup_ticks: Some(200),
  seed: Some(137),
  fog_of_war: false,
  playfield_margin_cells: None,

  initial_field_qe: Some(8.0),
  initial_field_freq: Some(150.0),
  initial_nutrient_water: Some(0.5),
  day_period_ticks: Some(600.0),
  year_period_ticks: Some(219000.0),
  axial_tilt: Some(0.26),
  self_sustaining_qe: Some(10.0),

  nuclei: [
    // ── SOL — infinite ───────────────────────────────────────────────────────
    (
      name: "sol",
      position: (0.0, 28.0),
      frequency_hz: 400.0,
      emission_rate_qe_s: 800.0,
      propagation_radius: 60.0,
      decay: InverseSquare,
      ambient_pressure: None,
    ),

    // ── GEOTHERMAL CORE ──────────────────────────────────────────────────────
