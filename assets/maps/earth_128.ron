(
  // ── Earth 128×128 — Calibrated to real Earth ratios ────────────────────────
  //
  // Axial tilt:     23.44° → 0.26                    ✓ exact
  // Days per year:  365                               ✓ exact
  // Ocean/land:     71%/29% → 5 ocean nuclei, 2 continental clusters
  // Geothermal:     0.03% of solar → geo_core emission ≈ 0.03× sol
  // Atmosphere:     thin global redistribution layer
  //
  width_cells: 128,
  height_cells: 128,
  cell_size: 2.0,
  origin: (-128.0, -128.0),
  warmup_ticks: Some(200),
  seed: Some(42),
  fog_of_war: false,
  playfield_margin_cells: None,

  initial_field_qe: Some(10.0),
  initial_field_freq: Some(85.0),
  initial_nutrient_water: Some(0.5),
  // Day = 1200 ticks. Year = 365 days = 438,000 ticks.
  day_period_ticks: Some(1200.0),
  year_period_ticks: Some(438000.0),
  axial_tilt: Some(0.26),
  self_sustaining_qe: Some(10.0),
  // 128²/48² ≈ 7.1 area ratio.
  emission_scale: Some(7.0),

  nuclei: [
    // ── THE SUN — infinite, InverseSquare ────────────────────────────────────
